{
  "name": "@inariwatch/capture",
  "version": "0.10.0",
  "description": "Lightweight error capture SDK for InariWatch — replaces Sentry with zero dependencies. Includes FullTrace session id propagation for causal debugging. Add @inariwatch/capture-replay for full session replay.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "inariwatch-capture": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "default": "./dist/auto.js"
    },
    "./next": {
      "types": "./dist/plugins/next.d.ts",
      "import": "./dist/plugins/next.js",
      "default": "./dist/plugins/next.js"
    },
    "./vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.js",
      "default": "./dist/plugins/vite.js"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "import": "./dist/plugins/webpack.js",
      "require": "./dist/plugins/webpack.js",
      "default": "./dist/plugins/webpack.js"
    },
    "./nuxt": {
      "types": "./dist/plugins/nuxt.d.ts",
      "import": "./dist/plugins/nuxt.js",
      "default": "./dist/plugins/nuxt.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./client": {
      "types": "./dist/client-entry.d.ts",
      "import": "./dist/client-entry.js",
      "default": "./dist/client-entry.js"
    },
    "./shield": {
      "types": "./dist/shield/index.d.ts",
      "import": "./dist/shield/index.js",
      "default": "./dist/shield/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    },
    "./fleet": {
      "types": "./dist/fleet/index.d.ts",
      "import": "./dist/fleet/index.js",
      "default": "./dist/fleet/index.js"
    },
    "./forensic": {
      "types": "./dist/forensic/index.d.ts",
      "import": "./dist/forensic/index.js",
      "default": "./dist/forensic/index.js"
    },
    "./browser-v2": {
      "types": "./dist/browser-v2/index.d.ts",
      "import": "./dist/browser-v2/index.js",
      "default": "./dist/browser-v2/index.js"
    },
    "./browser-v2/auto": {
      "types": "./dist/browser-v2/auto.d.ts",
      "import": "./dist/browser-v2/auto.js",
      "default": "./dist/browser-v2/auto.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "./dist/auto.js",
    "./dist/browser.js",
    "./dist/shield/index.js"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test --no-warnings test-setup/run-tests.mjs test/*.test.mjs test/causal/*.test.mjs test/intent/*.test.mjs",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "error-tracking",
    "monitoring",
    "inariwatch",
    "capture",
    "nextjs",
    "sentry-alternative"
  ],
  "author": "Jesus Bernal <info@jesusbr.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orbita-pos/inariwatch-capture.git"
  },
  "homepage": "https://inariwatch.com/docs#int-capture",
  "bugs": {
    "url": "https://github.com/orbita-pos/inariwatch-capture/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "rrweb": "^2.0.0-alpha.18"
  },
  "peerDependenciesMeta": {
    "rrweb": {
      "optional": true
    }
  },
  "//": "rrweb stays as an optional peer solely because `session.ts` (the legacy 60s ring buffer attached to errors) still uses it. Full Replay V2 moved to @inariwatch/capture-replay which depends on rrweb directly. The v2 ecosystem (agent / fleet / forensic / browser-v2) used to live in three separate packages and is now folded into this one as subpath exports — opt-in via `INARIWATCH_CAPTURE_V2=true` or by importing the subpath directly. Bundlers tree-shake the unused subpaths out for non-opt-in users.",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.5.0"
  }
}
